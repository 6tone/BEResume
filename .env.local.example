# 複製此檔案為 .env.local 並填入您的真實資料
# .env.local 已被 .gitignore 保護，不會上傳到 GitHub

VITE_PERSONAL_NAME=您的姓名
VITE_PERSONAL_TITLE=後端工程師 / 技術專案經理
VITE_PERSONAL_EMAIL=your-email@example.com
VITE_PERSONAL_PHONE=+886-9XX-XXX-XXX
VITE_PERSONAL_GITHUB=github.com/your-username
VITE_PERSONAL_LOCATION=Kaohsiung, Taiwan
# 照片路徑：放在 public/ 資料夾下，填相對路徑，例如 /avatar.jpg
# 若不使用照片請留空
VITE_PERSONAL_AVATAR=
